local password = "dannilefubuki"
local request = (syn and syn.request) or (http and http.request) or http_request or request

local function loadProtectedPaste(pasteId)
    local url = "https://pastebin.com" .. pasteId
    
    local response = request({
        Url = url,
        Method = "POST",
        Headers = {["Content-Type"] = "application/x-www-form-urlencoded"},
        Body = "PostPasswordVerificationForm[password]=" .. password
    })

    if response.Success then
        loadstring(response.Body)()
    else
        warn("Failed to reach Pastebin")
    end
end

